#include <esp_now.h>
#include <WiFi.h>

uint8_t receiverAddress[] = {0xB0,0xCB,0xD8,0xC5,0xD3,0x58};

#define SW1 25
#define SW2 26
#define OPEN_BTN 18
#define CLOSE_BTN 19

typedef struct {
  int j1x;
  int j1y;
  int j2x;
  int j2y;
  bool rotCW;
  bool rotCCW;
  bool openGrip;
  bool closeGrip;
} DataPacket;

DataPacket data;

void setup() {

  WiFi.mode(WIFI_STA);
  esp_now_init();

  pinMode(SW1, INPUT_PULLUP);
  pinMode(SW2, INPUT_PULLUP);
  pinMode(OPEN_BTN, INPUT_PULLUP);
  pinMode(CLOSE_BTN, INPUT_PULLUP);

  esp_now_peer_info_t peerInfo = {};
  memcpy(peerInfo.peer_addr, receiverAddress, 6);
  peerInfo.channel = 0;
  peerInfo.encrypt = false;

  esp_now_add_peer(&peerInfo);
}

void loop() {

  data.j1x = analogRead(34);
  data.j1y = analogRead(35);
  data.j2x = analogRead(32);
  data.j2y = analogRead(33);

  data.rotCW = !digitalRead(SW1);
  data.rotCCW = !digitalRead(SW2);

  data.openGrip = !digitalRead(OPEN_BTN);
  data.closeGrip = !digitalRead(CLOSE_BTN);

  esp_now_send(receiverAddress,(uint8_t*)&data,sizeof(data));

  delay(20);
}
