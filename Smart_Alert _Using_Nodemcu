#define BLYNK_TEMPLATE_ID "TMPL3vqTZWt8i"
#define BLYNK_TEMPLATE_NAME "Laser security system"
#define BLYNK_AUTH_TOKEN "GvblNaowZ2XGnGHyb5-T3Crdqf9PGOFF"

#define BLYNK_PRINT Serial

#include <ESP8266WiFi.h>
#include <BlynkSimpleEsp8266.h>
#include <Servo.h>

// WiFi
char ssid[] = "nani";
char pass[] = "123456789";

// Pins
#define LASER_PIN D1
#define LDR_PIN A0
#define BLUE_LED D5
#define RED_LED D6
#define SERVO_PIN D7

Servo myServo;

// Variables
bool systemON = false;
bool manualMode = false;
bool servoState = false;
int threshold = 500;
bool alertSent = false;

// ---------------- BLYNK ----------------

// System ON/OFF (V0)
BLYNK_WRITE(V0) {
  systemON = param.asInt();

  if (!systemON) {
    digitalWrite(LASER_PIN, LOW);
    digitalWrite(BLUE_LED, LOW);
    digitalWrite(RED_LED, LOW);
    myServo.write(0);

    Blynk.virtualWrite(V2, 0);
    Blynk.virtualWrite(V3, 0);
  } else {
    digitalWrite(LASER_PIN, HIGH);
  }
}

// Servo Switch Control (V1)
BLYNK_WRITE(V1) {
  servoState = param.asInt();

  if (manualMode) {
    if (servoState == 1) {
      myServo.write(180); // CLOSE
    } else {
      myServo.write(0);   // OPEN
    }
  }
}

// Mode Control (V4)
BLYNK_WRITE(V4) {
  manualMode = param.asInt(); // 0 = AUTO, 1 = MANUAL
}

// ---------------- SETUP ----------------

void setup() {
  Serial.begin(9600);

  pinMode(LASER_PIN, OUTPUT);
  pinMode(BLUE_LED, OUTPUT);
  pinMode(RED_LED, OUTPUT);

  myServo.attach(SERVO_PIN);
  myServo.write(0);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
}

// ---------------- LOOP ----------------

void loop() {
  Blynk.run();

  if (systemON && !manualMode) {
    int ldrValue = analogRead(LDR_PIN);
    Serial.println(ldrValue);

    if (ldrValue < threshold) {
      // 💙 SAFE
      digitalWrite(BLUE_LED, HIGH);
      digitalWrite(RED_LED, LOW);

      myServo.write(0);

      Blynk.virtualWrite(V2, 1);
      Blynk.virtualWrite(V3, 0);

      alertSent = false;
    } 
    else {
      // 🚨 ALERT
      digitalWrite(BLUE_LED, LOW);
      digitalWrite(RED_LED, HIGH);

      myServo.write(180);

      Blynk.virtualWrite(V2, 0);
      Blynk.virtualWrite(V3, 1);

      if (!alertSent) {
        Blynk.logEvent("laser_alert", "🚨 Intruder Detected!");
        alertSent = true;
      }
    }
  }

  delay(200);
}
